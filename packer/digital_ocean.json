{
    "variables": {
        "DO_TOKEN": "{{env `DO_TOKEN`}}"
    },
    "builders": [{
        "type":"digitalocean",
        "api_token":"{{user `DO_TOKEN`}}",
        "image":"centos-7-x64",
        "region":"nyc3",
        "size":"512mb",
        "ssh_username":"root",
        "snapshot_name":"base"
    }],
    "provisioners": [
        {
            "type": "shell",
            "inline": ["yum install gcc curl-devel expat-devel gettext-devel openssl-devel zlib-devel perl-ExtUtils-MakeMaker"]
        },
        {
            "type": "shell",
            "inline": ["cd /usr/local/src", "git clone https://github.com/git/git.git", "cd git"]
        },
        {
            "type":"shell",
            "inline": ["git checkout $(git ls-remote --tags origin | grep -oE 'v[0-9]+(.[0-9]+){2}$' | tail -n1)"]
        },
        {
            "type":"shell",
            "inline": ["autoconf"]
        },
        {
            "type":"shell",
            "inline": ["./configure"]
        },
        {
            "type":"shell",
            "inline": ["make", "make install"]
        }
    ]
}