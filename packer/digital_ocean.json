{
    "variables": {
        "DO_TOKEN": "{{env `DO_TOKEN`}}",
        "git_version": "2.20.1"
    },
    "builders": [{
        "type":"digitalocean",
        "api_token":"{{user `DO_TOKEN`}}",
        "image":"centos-7-x64",
        "region":"nyc3",
        "size":"512mb",
        "ssh_username":"root",
        "snapshot_name":"base"
    }],
    "provisioners": [
        {
            "type": "shell",
            "inline": ["yum -y install gcc curl-devel expat-devel gettext-devel openssl-devel perl-devel zlib-devel"]
        },
        {
            "type": "shell",
            "inline": [
                "cd /usr/local/src", 
                "curl https://mirrors.edge.kernel.org/pub/software/scm/git/git-{{user `git_version`}}.tar.gz -o git-{{user `git_version`}}.tar.gz",
                "tar -xzvf {{user `git_version`}}.tar.gz",
                "cd git-{{user `git_version`}}",
                "make configure",
                "./configure",
                "make",
                "make install"
            ]
        }
    ]
}